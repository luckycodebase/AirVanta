{
  "name": "airlytics-backend",
  "version": "1.0.0",
  "description": "Backend API for Airlytics Environmental Intelligence Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node scripts/seedPlants.js",
    "collect": "node -e \"require('./cron/collectAQI').collectAQI()\"",
    "stats": "node -e \"require('./cron/collectAQI').getCollectionStats()\"",
    "cleanup": "node -e \"require('./cron/collectAQI').cleanupOldData(365)\""
  },
  "keywords": [
    "aqi",
    "air-quality",
    "pollution",
    "environment",
    "prediction",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.6.5",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
